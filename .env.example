APP_NAME=UFPB Chat Multiatendente
API_V1_PREFIX=/api/v1
# SUPABASE - comentado para usar banco interno
# DATABASE_URL=postgresql+psycopg2://postgres.rcfjdwtwfbrlfaosvvno:s4MFwYYUz5kY3B9W@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# BANCO INTERNO UFPB
DATABASE_URL=postgresql+psycopg2://cau_ufpb:s4MFwYYUz5kY3B9W@automacoes_sti_ufpb_bd_whatsapp_interno_cau:5432/ufpb_chat?sslmode=disable

# Troque em produção por uma chave longa e aleatória.
# Exemplo para gerar: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_APP_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=43200

ADMIN_NAME=Diego Veras
ADMIN_EMAIL=diego.veras@gmail.com
ADMIN_BOOTSTRAP_FILE=/app/runtime/admin_bootstrap.txt

# URL de entrada no n8n (EvolutionAPI -> n8n).
# Observação: esta variável é informativa para operação e documentação.
N8N_INBOUND_WEBHOOK_URL=https://workflow.vqautomacao.com.br/webhook/entrada_chat_UFPB

# Entrada n8n -> FastAPI (/webhook):
# Use um token longo e aleatório e envie no header x-token (ou x-webhook-token) no n8n.
WEBHOOK_TOKEN=CHANGE_ME_INBOUND_WEBHOOK_TOKEN

# Saída FastAPI -> n8n (webhook de saída):
# URL do webhook de saída no n8n (ex.: /webhook/saida_chat_UFPB)
N8N_OUTBOUND_WEBHOOK_URL=

# none | header | basic | jwt
N8N_OUTBOUND_AUTH_TYPE=header

# Se N8N_OUTBOUND_AUTH_TYPE=header:
N8N_OUTBOUND_AUTH_HEADER_NAME=x-app-token
N8N_OUTBOUND_AUTH_HEADER_VALUE=CHANGE_ME_OUTBOUND_HEADER_TOKEN

# Se N8N_OUTBOUND_AUTH_TYPE=basic:
N8N_OUTBOUND_AUTH_BASIC_USERNAME=
N8N_OUTBOUND_AUTH_BASIC_PASSWORD=

# Se N8N_OUTBOUND_AUTH_TYPE=jwt:
N8N_OUTBOUND_AUTH_JWT_TOKEN=

# Lista separada por vírgula (ex.: http://localhost:3000,https://chat.ufpb.br)
CORS_ORIGINS=*

# Domínio público para URLs completas (ex.: https://chat.ufpb.br)
# Em produção, configure com o domínio real da aplicação
PUBLIC_DOMAIN=

# N8N Webhook Settings
# Modo dos webhooks: "test" usa URLs de teste, "prod" (padrão) usa URLs de produção
N8N_WEBHOOK_MODE=prod

# Webhook de Entrada (EvolutionAPI -> n8n)
N8N_INBOUND_WEBHOOK_URL_TEST=
N8N_INBOUND_WEBHOOK_URL_PROD=

# Token de autenticação do webhook de entrada
WEBHOOK_TOKEN=

# Webhook de Saída (FastAPI -> n8n)
N8N_OUTBOUND_WEBHOOK_URL_TEST=
N8N_OUTBOUND_WEBHOOK_URL_PROD=

# Configurações de ambiente
ENVIRONMENT=production
DEBUG=false

# AI Webhook Settings
# Modo do webhook: "test" usa AI_WEBHOOK_URL_TEST, "prod" (padrão) usa AI_WEBHOOK_URL_PROD
AI_WEBHOOK_MODE=prod
AI_WEBHOOK_URL_TEST=
AI_WEBHOOK_URL_PROD=

# Basic Auth para o webhook de consulta IA (opcional)
AI_WEBHOOK_USERNAME=
AI_WEBHOOK_PASSWORD=

# Ollama (local STI) - URL estática
OLLAMA_BASE_URL=https://ollama.sti.ufpb.br/
